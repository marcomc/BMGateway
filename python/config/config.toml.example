# Copy this file to ~/.config/__CONFIG_NAME__/config.toml or pass it with
# --config. Keep devices.toml beside this file unless you use an absolute
# device_registry path.

[gateway]
name = "__PROJECT_NAME__"
timezone = "Europe/Rome"
poll_interval_seconds = 15
device_registry = "devices.toml"
data_dir = "data"

[bluetooth]
adapter = "auto"
scan_timeout_seconds = 8
connect_timeout_seconds = 10

[mqtt]
enabled = true
host = "mqtt.local"
port = 1883
username = "homeassistant"
password = "CHANGE_ME"
base_topic = "bm_gateway"
discovery_prefix = "homeassistant"
retain_discovery = true
retain_state = false

[home_assistant]
enabled = true
status_topic = "homeassistant/status"
gateway_device_id = "bm_gateway"

[web]
enabled = true
host = "0.0.0.0"
port = 8080
