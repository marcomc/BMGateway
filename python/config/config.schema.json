{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BMGateway Config",
  "type": "object",
  "properties": {
    "gateway": {
      "type": "object",
      "required": ["name", "timezone", "poll_interval_seconds", "device_registry"],
      "properties": {
        "name": { "type": "string" },
        "timezone": { "type": "string" },
        "poll_interval_seconds": { "type": "integer", "minimum": 1 },
        "device_registry": { "type": "string" },
        "data_dir": { "type": "string" },
        "reader_mode": {
          "type": "string",
          "enum": ["fake", "live"]
        }
      }
    },
    "bluetooth": {
      "type": "object",
      "properties": {
        "adapter": { "type": "string" },
        "scan_timeout_seconds": { "type": "integer", "minimum": 1 },
        "connect_timeout_seconds": { "type": "integer", "minimum": 1 }
      }
    },
    "mqtt": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "host": { "type": "string" },
        "port": { "type": "integer", "minimum": 1 },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "base_topic": { "type": "string" },
        "discovery_prefix": { "type": "string" },
        "retain_discovery": { "type": "boolean" },
        "retain_state": { "type": "boolean" }
      }
    },
    "home_assistant": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "status_topic": { "type": "string" },
        "gateway_device_id": { "type": "string" }
      }
    },
    "web": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "host": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "show_chart_markers": { "type": "boolean" },
        "visible_device_limit": {
          "type": "integer",
          "enum": [2, 4, 6, 8]
        },
        "appearance": {
          "type": "string",
          "enum": ["light", "dark", "system"]
        },
        "default_chart_range": {
          "type": "string",
          "enum": ["raw", "1", "3", "5", "7", "30", "90", "365", "730", "all"]
        },
        "default_chart_metric": {
          "type": "string",
          "enum": ["voltage", "soc", "temperature"]
        },
        "language": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "zh-Hans",
            "hi",
            "es",
            "ar",
            "fr",
            "bn",
            "pt",
            "ru",
            "ur",
            "de",
            "it"
          ]
        }
      }
    },
    "usb_otg": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image_path": { "type": "string" },
        "size_mb": { "type": "integer", "minimum": 1, "maximum": 4096 },
        "gadget_name": { "type": "string" },
        "image_width_px": { "type": "integer", "minimum": 160 },
        "image_height_px": { "type": "integer", "minimum": 120 },
        "image_format": {
          "type": "string",
          "enum": ["jpeg", "png", "bmp"]
        },
        "appearance": {
          "type": "string",
          "enum": ["light", "dark"]
        },
        "refresh_interval_seconds": { "type": "integer", "minimum": 0 },
        "overview_devices_per_image": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "export_battery_overview": { "type": "boolean" },
        "export_fleet_trend": { "type": "boolean" },
        "fleet_trend_metrics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["voltage", "soc", "temperature"]
          }
        },
        "fleet_trend_range": {
          "type": "string",
          "enum": ["1", "3", "5", "7", "30", "90", "365", "730", "all"]
        },
        "fleet_trend_device_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "retention": {
      "type": "object",
      "properties": {
        "raw_retention_days": { "type": "integer", "minimum": 1 },
        "daily_retention_days": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
