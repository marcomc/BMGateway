[gateway]
name = "BMGateway"
timezone = "Europe/Rome"
poll_interval_seconds = 300
device_registry = "devices.toml"
data_dir = "data"
# Default is 5 minutes. Lower it only when you explicitly need tighter
# monitoring and accept the extra BLE, CPU, and battery overhead.
# Use "fake" for development or "live" to poll BM200 devices over BLE.
reader_mode = "fake"

[bluetooth]
adapter = "auto"
scan_timeout_seconds = 8
connect_timeout_seconds = 10

[mqtt]
enabled = true
host = "mqtt.local"
port = 1883
username = "homeassistant"
password = "CHANGE_ME"
base_topic = "bm_gateway"
discovery_prefix = "homeassistant"
retain_discovery = true
retain_state = false

[home_assistant]
enabled = true
status_topic = "homeassistant/status"
gateway_device_id = "bm_gateway"

[web]
enabled = true
host = "0.0.0.0"
port = 8080

[retention]
raw_retention_days = 180
daily_retention_days = 0
