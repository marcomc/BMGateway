[gateway]
name = "BMGateway"
timezone = "Europe/Rome"
poll_interval_seconds = 300
device_registry = "devices.toml"
data_dir = "data"
# Default is 5 minutes. Lower it only when you explicitly need tighter
# monitoring and accept the extra BLE, CPU, and battery overhead.
# Use "fake" for development or "live" to poll BM200 devices over BLE.
reader_mode = "fake"

[bluetooth]
adapter = "auto"
# BM6-family devices can be intermittent in discovery. Use a longer scan
# window and overall connect budget than generic BLE defaults.
scan_timeout_seconds = 15
connect_timeout_seconds = 45

[mqtt]
enabled = true
host = "mqtt.local"
port = 1883
username = "mqtt-user"
password = "CHANGE_ME"
base_topic = "bm_gateway"
discovery_prefix = "homeassistant"
retain_discovery = true
retain_state = false

[home_assistant]
enabled = true
status_topic = "homeassistant/status"
gateway_device_id = "bm_gateway"

[web]
enabled = true
host = "0.0.0.0"
port = 80
show_chart_markers = false
appearance = "system"
default_chart_range = "7"
default_chart_metric = "soc"
language = "auto"

[usb_otg]
enabled = false
image_path = "/var/lib/bm-gateway/usb-otg/bmgateway-frame.img"
size_mb = 64
gadget_name = "bmgw_frame"
image_width_px = 480
image_height_px = 234
image_format = "jpeg"
appearance = "light"
# Use 0 to export after each gateway polling cycle.
refresh_interval_seconds = 0
overview_devices_per_image = 5
export_battery_overview = true
export_fleet_trend = true
fleet_trend_metrics = ["soc"]
fleet_trend_range = "7"
# Empty means all configured devices. Settings writes explicit IDs when saved.
fleet_trend_device_ids = []

[retention]
raw_retention_days = 180
daily_retention_days = 0
